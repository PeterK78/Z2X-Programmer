<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:Z2XProgrammer.Resources.Strings"
             xmlns:converter="clr-namespace:Z2XProgrammer.Converter"
             xmlns:datamodel="clr-namespace:Z2XProgrammer.DataModel"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:Class="Z2XProgrammer.UserControls.Z2XFunctionKeyFunctionViewer"
             >

    <CollectionView x:Name="MainCollectionView" ItemsLayout="HorizontalList" VerticalOptions="Center">
        <CollectionView.ItemTemplate >
            <DataTemplate x:DataType="{x:Type sys:String}">
                <Border Stroke="White" StrokeThickness="1" StrokeShape="RoundRectangle 2,2,2,2" Background="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" HorizontalOptions="Center" HeightRequest="25">
                    <Label Text="{Binding .}" FontSize="10" FontAttributes="None" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" Padding="2,2,2,2" TextColor="{AppThemeBinding Light=White, Dark=Black}" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentView>
