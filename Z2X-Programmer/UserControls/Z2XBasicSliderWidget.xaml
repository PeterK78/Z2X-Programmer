<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:Z2XProgrammer.Resources.Strings"
             xmlns:converter="clr-namespace:Z2XProgrammer.Converter"
             x:Class="Z2XProgrammer.UserControls.Z2XBasicSliderWidget"
             >

    <FlexLayout Direction="Row" JustifyContent="SpaceBetween" HorizontalOptions="End">

        <!-- We use the following configuration of the VisualStateManager to switch between a horizontal and vertical layout -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>

                <!-- Portrait -->
                <VisualState x:Name="Portrait">
                    <VisualState.StateTriggers>
                        <OrientationStateTrigger Orientation="Portrait" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Property="Direction" Value="Column" />
                    </VisualState.Setters>
                </VisualState>

                <!-- LandscapeVertical -->
                <VisualState x:Name="LandscapeVertical">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Property="Direction" Value="Column" />
                    </VisualState.Setters>
                </VisualState>

                <!-- LandscapeHorizontal -->
                <VisualState x:Name="LandscapeHorizontal">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200"/>
                        <OrientationStateTrigger Orientation="Landscape" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Property="Direction" Value="Row" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <VerticalStackLayout HorizontalOptions="Start" VerticalOptions="Center">
            <Label x:Name="MyTitleLabel" Style="{StaticResource Z2XProgrammerLabelHeading3Style}" HorizontalOptions="Start" VerticalOptions="Center" LineBreakMode="WordWrap" />
            <Label x:Name="MyDecriptionLabel" Style="{StaticResource Z2XProgrammerLabelStandardStyle}" HorizontalOptions="Start" VerticalOptions="Center" LineBreakMode="WordWrap" />
        </VerticalStackLayout>
        <VerticalStackLayout HorizontalOptions="Start">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Start">
                <Slider x:Name="MySlider" ValueChanged="MySlider_ValueChanged" WidthRequest="200" Style="{StaticResource Z2XSlider}" HorizontalOptions="Center"></Slider>
                <Border x:Name="MyHeatIndicator" Style="{StaticResource Z2XBorderFrame}" WidthRequest="200" HeightRequest="4" HorizontalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="Green" Offset="0.0" />
                            <GradientStop Color="Yellow" Offset="0.2" />
                            <GradientStop Color="Orange" Offset="0.3" />
                            <GradientStop Color="Red" Offset="0.5" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Label  x:Name="MySliderLabel" Style="{StaticResource Z2XProgrammerLabelStandardStyle}" HorizontalOptions="Center" VerticalOptions="Center"></Label>
            </VerticalStackLayout>
            <Label x:Name="MyCVLabel" Style="{StaticResource Z2XProgrammerLabelAdditionalCVValuesStyle}" IsVisible="False" HorizontalOptions="Center" HorizontalTextAlignment="Center"></Label>
        </VerticalStackLayout>

    </FlexLayout>

</ContentView>
