<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Z2XProgrammer.Pages.MaintenancePage"
             xmlns:converter="clr-namespace:Z2XProgrammer.Converter"
             xmlns:strings="clr-namespace:Z2XProgrammer.Resources.Strings"
             xmlns:usercontrols="clr-namespace:Z2XProgrammer.UserControls"
             xmlns:viewmodel="clr-namespace:Z2XProgrammer.ViewModel"
             x:DataType="viewmodel:MaintenanceViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource AppBackground_Light}, Dark={StaticResource AppBackground_Dark}}"
             Style="{StaticResource Z2XProgrammerContentPageStyle}"
             Title="{x:Static strings:AppResources.FlyoutItemMaintenanceText}">

    <ContentPage.Resources>
        <converter:InverseBooleanConverter x:Key="boolInvert" />
    </ContentPage.Resources>

    <ScrollView x:Name="PageScrollView" Orientation="Vertical" Padding="0,0,20,0">
        <VerticalStackLayout >

            <!-- Page Title -->
            <HorizontalStackLayout>
                <Image Source="{AppThemeBinding Light=ic_fluent_wrench_screwdriver_24_regular.png, Dark=ic_fluent_wrench_screwdriver_24_dark.png}" Margin="0,0,10,0" ></Image>
                <Label Style="{StaticResource Z2XProgrammerLabelHeading1Style}" Text="{x:Static strings:AppResources.FlyoutItemMaintenanceText}" VerticalOptions="Center"  HorizontalOptions="Start" />
            </HorizontalStackLayout>

            <!-- The selected decoder does not support any of the settings provided on this page  -->
            <HorizontalStackLayout IsVisible="{Binding Path=AnyMaintenanceSettingsSupported,Converter={StaticResource boolInvert}}" Margin="0,20,0,20" >
                <Image Source="{AppThemeBinding Light=ic_fluent_info_24_regular.png, Dark=ic_fluent_info_24_dark.png}" WidthRequest="24" Margin="0,0,20,0" ></Image>
                <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Text="{x:Static strings:AppResources.AlertNoFeatureSupported}" VerticalOptions="Center"  HorizontalOptions="Start" />
            </HorizontalStackLayout>

            <!-- Page sheet content -->
            <VerticalStackLayout>

                <!-- Decoder reset in CV8 RCN225_DECODERRESET_CV8 -->
                <Label Style="{StaticResource Z2XProgrammerLabelHeading2Style}" HorizontalOptions="Start" Text="{x:Static strings:AppResources.FrameSecurityDecoderResetTitle}" VerticalOptions="Center" IsVisible="{Binding RCN225_DECODERRESET_CV8}" />
                <Border Style="{StaticResource Z2XBorderFrame}" IsVisible="{Binding RCN225_DECODERRESET_CV8}" >
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>

                        <Image Margin="0,5,0,0" Grid.Row="0" Grid.Column="0" Source="{AppThemeBinding Light=ic_fluent_arrow_reset_24_regular.png, Dark=ic_fluent_arrow_reset_24_regular.png}" HorizontalOptions="Start" VerticalOptions="Start" HeightRequest="24"></Image>
                        <Label  Margin="0,0,10,0" Grid.Row="0" Grid.Column="1" x:Name="FrameSecurityDecoderResetLabel" Style="{StaticResource Z2XProgrammerLabelStandardStyle}" HorizontalOptions="Start" Text="{x:Static strings:AppResources.FrameSecurityDecoderResetLabel}" VerticalOptions="Center" LineBreakMode="WordWrap"/>

                        <Button Grid.Row="1" Grid.Column="1" Margin="0,5,0,0"  WidthRequest="150" HorizontalOptions="End" Style="{StaticResource Z2XProgrammerStandardButtonStyle}" Text="{x:Static strings:AppResources.FrameSecurityDecoderResetButtonLabel}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MaintenanceViewModel}}, Path=ResetDecoderCommand}"  VerticalOptions="End" ></Button>

                    </Grid>
                </Border>

                <!-- ZIMO self test of MS function decoders  -->
                <Label Style="{StaticResource Z2XProgrammerLabelHeading2Style}" Text="{x:Static strings:AppResources.FrameMaintenanceSelfTestTitle}" VerticalOptions="Center"  HorizontalOptions="Start" IsVisible="{Binding ZIMO_SELFTEST_CV30}" />
                <Border Style="{StaticResource Z2XBorderFrame}" IsVisible="{Binding ZIMO_SELFTEST_CV30}">
                    <VerticalStackLayout>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                            </Grid.RowDefinitions>

                            <Image Margin="0,5,0,0" Grid.Row="0" Grid.Column="0" Source="{AppThemeBinding Light=ic_fluent_doctor_24_regular.png, Dark=ic_fluent_doctor_24_dark.png}" HorizontalOptions="Start" VerticalOptions="Start" HeightRequest="24"></Image>
                            <Label Grid.Row="0" Grid.Column="1"  Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Text="{x:Static strings:AppResources.FrameMaintenanceSelfTestDescription}" VerticalOptions="Center"  HorizontalOptions="Start"/>

                            <usercontrols:Z2XBasicEntryWidget Margin="0,10,0,0" x:Name="FrameMaintenanceSelfTestLabel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" IsReadOnly="False" TitleText="{x:Static strings:AppResources.FrameMaintenanceSelfTestLabel}" Text="{Binding ZIMODecoderErrorState}"  CVVisible="{Binding AdditionalDisplayOfCVValues, Mode=TwoWay}" CVText="{Binding SelectedDCCAddressModeVehicleAddrCVConfiguration, Mode=TwoWay}"></usercontrols:Z2XBasicEntryWidget>

                            <FlexLayout Direction="Row" JustifyContent="End" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" HorizontalOptions="End">

                                <!-- We use the following configuration of the VisualStateManager to switch between a horizontal and vertical layout -->
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup>

                                        <!-- Portrait -->
                                        <VisualState x:Name="Portrait">
                                            <VisualState.StateTriggers>
                                                <OrientationStateTrigger Orientation="Portrait" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Property="Direction" Value="Column" />
                                            </VisualState.Setters>
                                        </VisualState>

                                        <!-- LandscapeVertical -->
                                        <VisualState x:Name="LandscapeVertical">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="0"/>
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Property="Direction" Value="Column" />
                                            </VisualState.Setters>
                                        </VisualState>

                                        <!-- LandscapeHorizontal -->
                                        <VisualState x:Name="LandscapeHorizontal">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="950"/>
                                                <OrientationStateTrigger Orientation="Landscape" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Property="Direction" Value="Row" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Button  Style="{StaticResource Z2XProgrammerStandardButtonStyle}"  Margin="10,5,0,0" Text="{x:Static strings:AppResources.ButtonStartZIMOSelftTest}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MaintenanceViewModel}}, Path=StartZIMOSelfTestCommand}"  WidthRequest="250" VerticalOptions="Center" HorizontalOptions="End" ></Button>
                                <Button  Style="{StaticResource Z2XProgrammerStandardButtonStyle}"  Margin="10,5,0,0" Text="{x:Static strings:AppResources.ButtonResetZIMOErrorMemory}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MaintenanceViewModel}}, Path=ResetErrorMemoryCommand}"  WidthRequest="250" VerticalOptions="Center" HorizontalOptions="End" ></Button>
                            </FlexLayout>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>


        </VerticalStackLayout>
    </ScrollView>
</ContentPage>