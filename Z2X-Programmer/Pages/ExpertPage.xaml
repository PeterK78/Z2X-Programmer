<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Z2XProgrammer.Pages.ExpertPage"
             xmlns:strings="clr-namespace:Z2XProgrammer.Resources.Strings"
             xmlns:converter="clr-namespace:Z2XProgrammer.Converter"
             xmlns:viewmodel="clr-namespace:Z2XProgrammer.ViewModel"
             xmlns:datamodel="clr-namespace:Z2XProgrammer.DataModel"
             xmlns:usercontrols="clr-namespace:Z2XProgrammer.UserControls"
             x:DataType="viewmodel:ExpertViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource AppBackground_Light}, Dark={StaticResource AppBackground_Dark}}"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Style="{StaticResource Z2XProgrammerContentPageStyle}"
             x:Name="ThisPage"
             Title="{x:Static strings:AppResources.FlyoutItemExpertTitle}">

    <ContentPage.Resources>
        <converter:InverseBooleanConverter x:Key="boolInvert" />
    </ContentPage.Resources>

    <ScrollView x:Name="PageScrollView" Orientation="Vertical" Padding="0,0,20,0">

        <VerticalStackLayout>

            <!-- Page Title -->
            <HorizontalStackLayout>
                <Image Source="{AppThemeBinding Light=ic_fluent_toolbox_24_regular.png, Dark=ic_fluent_toolbox_24_dark.png}" Margin="0,0,10,0" ></Image>
                <Label Style="{StaticResource Z2XProgrammerLabelHeading1Style}" Text="{x:Static strings:AppResources.FlyoutItemExpertTitle}" VerticalOptions="Center"  HorizontalOptions="Start" />
            </HorizontalStackLayout>

            <!-- Read & Write single CVs  -->
            <Label Style="{StaticResource Z2XProgrammerLabelHeading2Style}" Text="{x:Static strings:AppResources.FrameExpertSettingsCVReadWriteTitle}" VerticalOptions="Center"  HorizontalOptions="Start" />
            <Border Style="{StaticResource Z2XBorderFrame}" IsEnabled="{Binding Path=ActivityReadWriteCVOngoing,Converter={StaticResource boolInvert}}" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <ActivityIndicator Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Grid.RowSpan="4" IsVisible="{Binding ActivityReadWriteCVOngoing}" IsRunning="{Binding ActivityReadWriteCVOngoing}"></ActivityIndicator>

                    <usercontrols:Z2XBasicEntryWidget x:Name="FrameExpertSettingsCVReadWriteCVLabel" Margin="0,10,0,0" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" IsReadOnly="False" Text="{Binding CvNumber}" TitleText="{x:Static strings:AppResources.FrameExpertSettingsCVReadWriteCVLabel}" CVVisible="{Binding AdditionalDisplayOfCVValues, Mode=TwoWay}" CVText="{Binding SelectedDCCAddressModeVehicleAddrCVConfiguration}" >
                        <usercontrols:Z2XBasicEntryWidget.EntryBehaviors>
                            <toolkit:NumericValidationBehavior
                                InvalidStyle="{StaticResource Z2XInvalidEntry}"
                                ValidStyle="{StaticResource Z2XValidEntry}"
                                Flags="ValidateOnValueChanged"
                                MinimumValue="1"
                                MaximumValue="1024"
                                MaximumDecimalPlaces="0"
                                >
                            </toolkit:NumericValidationBehavior>
                        </usercontrols:Z2XBasicEntryWidget.EntryBehaviors>
                    </usercontrols:Z2XBasicEntryWidget>

                    <usercontrols:Z2XBasicEntryWidget x:Name="FrameExpertSettingsCVReadWriteCVValue" Margin="0,10,0,0" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" IsReadOnly="False" Text="{Binding Value}" TitleText="{x:Static strings:AppResources.FrameExpertSettingsCVReadWriteCVValue}" CVVisible="{Binding AdditionalDisplayOfCVValues, Mode=TwoWay}" CVText="{Binding SelectedDCCAddressModeVehicleAddrCVConfiguration}" >
                        <usercontrols:Z2XBasicEntryWidget.EntryBehaviors>
                            <toolkit:NumericValidationBehavior
                                InvalidStyle="{StaticResource Z2XInvalidEntry}"
                                ValidStyle="{StaticResource Z2XValidEntry}"
                                Flags="ValidateOnValueChanged"
                                MinimumValue="0"
                                MaximumValue="255"
                                MaximumDecimalPlaces="0"
                                >
                            </toolkit:NumericValidationBehavior>
                        </usercontrols:Z2XBasicEntryWidget.EntryBehaviors>
                    </usercontrols:Z2XBasicEntryWidget>

                    <FlexLayout Direction="Row" JustifyContent="SpaceBetween" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HorizontalOptions="End" Margin="0,10,0,0">

                        <!-- We use the following configuration of the VisualStateManager to switch between a horizontal and vertical layout -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>

                                <!-- Portrait -->
                                <VisualState x:Name="Portrait">
                                    <VisualState.StateTriggers>
                                        <OrientationStateTrigger Orientation="Portrait" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Column" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- LandscapeVertical -->
                                <VisualState x:Name="LandscapeVertical">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="0"/>
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Column" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- LandscapeHorizontal -->
                                <VisualState x:Name="LandscapeHorizontal">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="950"/>
                                        <OrientationStateTrigger Orientation="Landscape" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Row" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Label Style="{StaticResource Z2XProgrammerLabelHeading3Style}" Text="{x:Static strings:AppResources.FrameExpertSettingsCVReadWriteCVBits}" VerticalOptions="Center"  HorizontalOptions="Start" />
                        <HorizontalStackLayout HorizontalOptions="End">
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit7}"></CheckBox>
                                <Label Text="Bit 7"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit6}"></CheckBox>
                                <Label Text="Bit 6"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit5}"></CheckBox>
                                <Label Text="Bit 5"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit4}"></CheckBox>
                                <Label Text="Bit 4"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit3}"></CheckBox>
                                <Label Text="Bit 3"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit2}"></CheckBox>
                                <Label Text="Bit 2"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit1}"></CheckBox>
                                <Label Text="Bit 1"></Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <CheckBox IsChecked="{Binding Bit0}" ></CheckBox>
                                <Label Text="Bit 0"></Label>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </FlexLayout>

                    <FlexLayout Direction="Row"  Margin="0,40,0,0" JustifyContent="End" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" HorizontalOptions="End">

                        <!-- We use the following configuration of the VisualStateManager to switch between a horizontal and vertical layout -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>

                                <!-- Portrait -->
                                <VisualState x:Name="Portrait">
                                    <VisualState.StateTriggers>
                                        <OrientationStateTrigger Orientation="Portrait" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Column" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- LandscapeVertical -->
                                <VisualState x:Name="LandscapeVertical">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="0"/>
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Column" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- LandscapeHorizontal -->
                                <VisualState x:Name="LandscapeHorizontal">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="950"/>
                                        <OrientationStateTrigger Orientation="Landscape" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Row" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Button Margin="10,5,0,0" ImageSource="{AppThemeBinding Light=ic_fluent_arrow_download_24_dark.png , Dark=ic_fluent_arrow_download_24_regular.png}" Style="{StaticResource Z2XProgrammerStandardButtonStyle}" Text="{x:Static strings:AppResources.FrameExpertSettingsCVReadWriteButtonWriteCV}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ExpertViewModel}}, Path=WriteCVCommand}" WidthRequest="200" ></Button>
                        <Button Margin="10,5,0,0" ImageSource="{AppThemeBinding Light=ic_fluent_arrow_upload_24_dark.png, Dark=ic_fluent_arrow_upload_24_regular.png}" Style="{StaticResource Z2XProgrammerStandardButtonStyle}" Text="{x:Static strings:AppResources.FrameExpertSettingsCVReadWriteButtonReadCV}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ExpertViewModel}}, Path=ReadCVCommand}" WidthRequest="200" ></Button>
                        
                    </FlexLayout>
                    
                </Grid>


            </Border>


            <!-- Read CV-Set -->
            <Label Style="{StaticResource Z2XProgrammerLabelHeading2Style}" Text="{x:Static strings:AppResources.FrameExpertReadCVSetTitle}" VerticalOptions="Center"  HorizontalOptions="Start" />
            <Border Style="{StaticResource Z2XBorderFrame}" IsEnabled="{Binding Path=ActivityReadWriteCVOngoing,Converter={StaticResource boolInvert}}" >

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <!-- The description -->
                    <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Text="{x:Static strings:AppResources.FrameExpertReadCVSetDescription}" VerticalOptions="Center"  HorizontalOptions="Start" />

                    <HorizontalStackLayout Margin="0,40,0,0"  Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"  HorizontalOptions="End">
                        <Button ImageSource="{AppThemeBinding Light=ic_fluent_document_bullet_list_arrow_left_24_dark.png , Dark=ic_fluent_document_bullet_list_arrow_left_24_regular.png}" Style="{StaticResource Z2XProgrammerStandardButtonStyle}" Text="{x:Static strings:AppResources.FrameExpertSettingsCVReadCVSetButton}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ExpertViewModel}}, Path=ImportCVSetFileCommand}" WidthRequest="200" ></Button>
                    </HorizontalStackLayout>

                </Grid>

            </Border>

            <!-- List of configuration variables -->
            <Label Style="{StaticResource Z2XProgrammerLabelHeading2Style}" Text="{x:Static strings:AppResources.FrameExpertCVListTitle}" VerticalOptions="Center"  HorizontalOptions="Start" />
            <Border Style="{StaticResource Z2XBorderFrame}">

                <VerticalStackLayout>

                    <!-- The description -->
                    <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Text="{x:Static strings:AppResources.FrameExpertCVListDescription}" VerticalOptions="Center"  HorizontalOptions="Start" />

                    <!-- The warning -->
                    <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Text="{x:Static strings:AppResources.FrameExpertCVListNote}" VerticalOptions="Center"  HorizontalOptions="Start" Margin="0,20,0,10" />

                    <!-- The table -->
                    <Border Padding="5,5,5,5" Margin="0,20,0,0">

                        <CollectionView ItemsSource="{Binding ConfigurationVariables}" SelectedItem="{Binding SelectedConfigurationVariable}" HeightRequest="300" SelectionMode="Single" SelectionChangedCommand="{Binding CVSelectedCommand, Mode=OneWay}">
                            <CollectionView.Header>
                                <Grid ColumnDefinitions="*,*,*">
                                    <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderNormal_Light}, Dark={StaticResource TableHeaderNormal_Dark}}" Text="{x:Static strings:AppResources.FrameExpertCVHeaderCVNumber}" Grid.Column="0"/>
                                    <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderNormal_Light}, Dark={StaticResource TableHeaderNormal_Dark}}" Text="{x:Static strings:AppResources.FrameExpertCVHeaderCVValue}" Grid.Column="1"/>
                                    <Label Style="{StaticResource Z2XProgrammerLabelStandardStyle}" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderNormal_Light}, Dark={StaticResource TableHeaderNormal_Dark}}" Text="Aktiviert" Grid.Column="2"/>
                                </Grid>
                            </CollectionView.Header>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="datamodel:ConfigurationVariableType">
                                    <Grid ColumnDefinitions="*,*,*">
                                        <Label Grid.Column="0" Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Text="{Binding Number, StringFormat='CV {0}'}" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Style="{StaticResource Z2XProgrammerLabelStandardStyle}" Text="{Binding Value}" VerticalOptions="Center" />
                                        <CheckBox Grid.Column="2" IsChecked="{Binding Enabled}" IsEnabled="False"  VerticalOptions="Center"></CheckBox>
                                    </Grid>
                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </Border>

                    
                    
                    <FlexLayout Direction="Row"  Margin="0,40,0,0" JustifyContent="End" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"  HorizontalOptions="End">

                        <!-- We use the following configuration of the VisualStateManager to switch between a horizontal and vertical layout -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>

                                <!-- Portrait -->
                                <VisualState x:Name="Portrait">
                                    <VisualState.StateTriggers>
                                        <OrientationStateTrigger Orientation="Portrait" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Column" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- LandscapeVertical -->
                                <VisualState x:Name="LandscapeVertical">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="0"/>
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Column" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- LandscapeHorizontal -->
                                <VisualState x:Name="LandscapeHorizontal">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="950"/>
                                        <OrientationStateTrigger Orientation="Landscape" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="Direction" Value="Row" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    
                        <Button Margin="10,5,0,0" Style="{StaticResource Z2XProgrammerStandardButtonStyle}" Text="{x:Static strings:AppResources.FrameExpertSettingsEnableAllCVs}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ExpertViewModel}}, Path=EnableAllCVsCommand}" WidthRequest="250" ImageSource="{AppThemeBinding Light=ic_fluent_select_all_on_24_dark.png, Dark=ic_fluent_select_all_on_24_regular.png}"></Button>
                        <Button Margin="10,5,0,0" Style="{StaticResource Z2XProgrammerStandardButtonStyle}" Text="{x:Static strings:AppResources.FrameExpertSettingsEnableDisableCV}" CommandParameter="{Binding .}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ExpertViewModel}}, Path=EnableDisableCVCommand}" WidthRequest="250" ImageSource="{AppThemeBinding Light=ic_fluent_toggle_multiple_24_dark.png, Dark=ic_fluent_toggle_multiple_24_regular.png}"></Button>
                        
                    </FlexLayout>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>


    </ScrollView>
</ContentPage>